def get_city_context(city: str, language: str = "zh-Hant") -> str:
    """根据城市生成定向解读上下文（支持zh-Hant/zh-Hans/en）"""
    if not city:
        return ""
    if language == "en":
        profile = CITY_PROFILES_EN.get(city, "a diverse city with a mixed economy and service sector")
        return (f"\n\n📍【City-Targeted Analysis — {city}】"
                f"The user currently lives/works in {city}. {profile}. "
                f"Your reading MUST incorporate the city's specific context (industries, climate, culture) "
                f"so the user feels this is a personalized reading for {city}, not a generic template.")
    else:
        profile = CITY_PROFILES.get(city, "该城市以多元经济和服务业为主")
        return (f"\n\n📍【城市定向分析 — {city}】"
                f"用户目前在【{city}】生活/工作。{profile}。"
                f"请解读时必须结合该城市特点进行分析（产业/气候/文化），让读者感受到这是针对{city}的专属解读，而非通用模板。")


