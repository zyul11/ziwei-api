# ─── 统计 ──────────────────────────────────────────────────────
@app.get("/v1/stats")
def public_stats():
    """公开统计 — 展示项目使用数据（信任背书用）"""
    total_keys = db_conn.execute("SELECT COUNT(*) FROM api_keys").fetchone()[0]
    total_usage = db_conn.execute("SELECT COUNT(*) FROM usage_log").fetchone()[0]
    return {"success": True, "data": {"total_keys": total_keys, "total_calls": total_usage, "已服务人次": total_usage}}

@app.post("/v1/paipan", response_model=PaiPanResponse)
def paipan(req: PaiPanRequest, key: str = Depends(get_api_key)):
    """排盘 + AI 解读"""
    try:
        # 1. 排盘
        chart = run_engine(req.year, req.month, req.day, req.hour, req.gender)
        if not chart.get("success"):
            return PaiPanResponse(success=False, error="排盘失败")

        # 2. AI 解读
        reading = ""
        if client:
            try:
                prompt = load_style_prompt(req.style, req.language)
prompt = load_daily_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
                    model="deepseek-chat",
                    messages=[
                        {"role": "system", "content": prompt},
                        {"role": "user", "content": f"请解读以下紫微斗数命盘：\n\n{chart_json}{city_ctx}"},
                    ],
                    temperature=0.7,
                    max_tokens=2000,
                    timeout=15,
                )
                reading = resp.choices[0].message.content or ""
                # token tracking
                in_tok = resp.usage.prompt_tokens if resp.usage else 0
                out_tok = resp.usage.completion_tokens if resp.usage else 0
                # cost: 每500 tokens = 1分
                cost = max(1, (in_tok + out_tok) // 1000)
                log_usage(key, "paipan", cost, in_tok, out_tok)
                deduct_balance(key, cost)
            except Exception as e:
                reading = f"[AI解读暂时不可用: {str(e)}]"
                cost = 1
                log_usage(key, "paipan", cost)
                deduct_balance(key, cost)
        else:
            log_usage(key, "paipan", 1)
            deduct_balance(key, 1)

        return PaiPanResponse(success=True, data={
            "chart": chart,
            "reading": reading,
        })

    except Exception as e:
        return PaiPanResponse(success=False, error=str(e))

@app.post("/v1/paipan-only", response_model=PaiPanResponse)
def paipan_only(req: PaiPanRequest, key: str = Depends(get_api_key)):
    """仅排盘，不调用 AI"""
    try:
        chart = run_engine(req.year, req.month, req.day, req.hour, req.gender)
        if not chart.get("success"):
            return PaiPanResponse(success=False, error="排盘失败")
        log_usage(key, "paipan-only", 1)
        deduct_balance(key, 1)
        return PaiPanResponse(success=True, data={"chart": chart})
    except Exception as e:
        return PaiPanResponse(success=False, error=str(e))

# ─── 每日运势 ────────────────────────────────────────────────

def load_daily_prompt(style: str, language: str = "zh-Hant") -> str:
    """每日运势提示词（支持zh-Hant/zh-Hans/en）"""
    lang_zh = "zh-Hant" if language == "zh-Hant" else "zh-Hans"
    
    if language == "en":
        prompts = {
            "modern": """You are an environmental psychology and color art analyst. The user has provided their Zi Wei Dou Shu birth chart. Give them a personalized daily tip based on **today's date (current day's energy)**.

Analysis framework:
1. **Today's Energy Theme** — Based on user's Life Palace main star + today's Heavenly Stem/Earthly Branch, what energy stands out today
2. **Today's Do's & Don'ts** — Based on daily Four Transformations affecting the chart, give specific actionable advice
3. **Lucky Colors** — Based on color psychology + today's Five Element supplement, recommend 2-3 colors
4. **Active Palace** — Which palace is activated today (Wealth? Career? Relationships?) and what it means
5. **Space Tip** — A small home/office adjustment from an environmental art perspective

⚠️ Present from environmental psychology, color psychology and natural rhythm perspectives only. Don't say "fortune-telling" or "divination". Keep tone light and practical. Max 300 words.""",

            "classical": """You are a classical Zi Wei Dou Shu and Chinese calendar expert. The user has provided their birth chart. Give a classical-style daily fortune based on the current day's energy.

Analysis framework:
1. **Today's Spirits** — The interaction between today's Heavenly Stem/Earthly Branch and the chart's palaces, pointing out auspicious/inauspicious influences
2. **Palace Activation** — Which palace is triggered by today's Four Transformations, and whether it's favorable
3. **Do's & Don'ts** — Based on today's calendar combined with the user's chart, specific recommendations
4. **Five Element Balance** — Which elemental energy dominates today and how the user can harmonize
5. **Timing Tip** — Which hour of the day is most favorable

⚠️ Use classical astrology judgment style. End with: "This is for entertainment and reference only." Max 300 words.""",

            "poetic": """You are a healing energy guide, delivering daily energy through poetic, warm language.

Analysis framework:
1. **Morning Poem** — A short warm poem to open, fitting today's energy
2. **How You Look Today** — Describe the user's likely state today from the chart perspective
3. **A Small Ritual** — A tiny healing action to do today (brew a tea, take a noon walk, etc.)
4. **Today's Mantra** — A short blessing phrase for the user

⚠️ Use warm, beautiful language with metaphors and imagery. 3-5 sentences per paragraph. End with: "This is for entertainment and reference only." Max 300 words.""",
        }
    else:
        prompts = {
            "modern": f"""你是一个环境心理学与色彩艺术分析师。用户提供了自己的紫微斗数命盘，请结合**今天的日期（流日）**，给出基于用户本命盘的个性化每日提示。

分析框架：
1. **今日能量主题** — 结合用户命宫主星特性 + 今日流日干支，今天什么方面的能量最突出
2. **今日宜/忌** — 基于用户命盘流日四化引动，给出具体行动建议
3. **幸运色** — 基于色彩心理学 + 今日五行补益，推荐 2-3 个颜色
4. **关注宫位** — 今天哪个宫位能量被引动（财帛？官禄？人际？），对应现实生活建议
5. **空间小提示** — 环境艺术角度的今日家居/办公调整

⚠️ 只从环境心理学、色彩心理学、自然节律角度表达。不说"算命""占卜"。用词轻松实用。请使用{lang_zh}回答。总字数 300 字以内。""",

            "classical": f"""你是精通紫微斗数与黄历择日的传统命师。用户提供了自己的命盘，请结合流日给出古典风格的每日运势。

分析框架：
1. **今日神煞** — 流日与命宫的冲合关系，指出今日吉神/凶煞
2. **十二宫引动** — 哪一宫被流日四化引动，吉凶如何
3. **宜忌** — 参照黄历今日冲合，结合用户命盘给出具体宜忌（如：利求财、忌远行）
4. **五行调候** — 今日五行之气偏向何处，用户如何补益
5. **择时提示** — 今日哪个时辰对用户最利

⚠️ 用传统命理断语风格，半文言表达。请使用{lang_zh}回答。结尾注明"仅供娱乐参考"。总字数 300 字以内。""",

            "poetic": f"""你是治愈系能量指引师，以诗意温暖的语言为用户传递每日能量。

分析框架：
1. **清晨的一句诗** — 一句温暖的短诗开场，贴合今日能量氛围
2. **今日的你的样子** — 从命盘角度描绘用户今天可能的状态（温柔/坚定/安静等）
3. **一个小仪式** — 今日可做的微小治愈动作（泡一杯茶、午间散步等）
4. **今日箴言** — 一句送给用户的短句祝福

⚠️ 语言优美温暖，多用比喻和画面感表达。每段3-5句。请使用{lang_zh}回答。结尾注明"仅供娱乐参考"。总字数 300 字以内。""",
        }
    return prompts.get(style, prompts["modern"])

class DailyRequest(BaseModel):
    year: int = Field(..., ge=1900, le=2100)
    month: int = Field(..., ge=1, le=12)
    day: int = Field(..., ge=1, le=31)
    hour: float = Field(..., ge=0, le=23)
    gender: str = Field(..., pattern="^(male|female)$")
    style: str = Field("modern", pattern="^(modern|classical|poetic)$")
    city: str = Field("", max_length=100, description="所在城市")
    language: str = Field("zh-Hant", pattern="^(zh-Hant|zh-Hans|en)$", description="输出语言")

class DailyResponse(BaseModel):
    success: bool
    data: Optional[dict] = None
    error: Optional[str] = None

@app.post("/v1/daily", response_model=DailyResponse)
def daily_fortune(req: DailyRequest, key: str = Depends(get_api_key)):
    """每日运势 — 基于命盘+流日"""
    try:
        today = date.today()
        
        # 1. 获取用户命盘
        chart = run_engine(req.year, req.month, req.day, req.hour, req.gender)
        if not chart.get("success"):
            return DailyResponse(success=False, error="排盘失败")
        
        # 2. 获取今日流日信息
        lunar_req = jmod.dumps({"year": today.year, "month": today.month, "day": today.day, "hour": 12, "gender": "male"})
        proc = subprocess.run(
            [_NODE, str(ENGINE_PATH)],
            input=lunar_req, capture_output=True, text=True, timeout=10, cwd=str(BASE_DIR),
        )
        today_chart = {}
        if proc.returncode == 0:
            today_chart = jmod.loads(proc.stdout)
        
        today_info = today_chart.get("基本信息", {})
        context = {
            "日期": f"{today.year}年{today.month}月{today.day}日",
            "农历": today_info.get("农历", ""),
            "干支": today_info.get("八字", "").split(" ")[0] if today_info.get("八字") else "",
            "星期": "日一二三四五六"[today.weekday()],
prompt = load_daily_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
        # 3. AI 解读
        reading = ""
        if client:
            try:
                chart_json = jmod.dumps({
                    "基本资料": chart.get("基本信息"),
                    "命盘": chart.get("命盘"),
                    "大限": chart.get("大限"),
                }, ensure_ascii=False, indent=2)
prompt = load_daily_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
                    messages=[
                        {"role": "system", "content": prompt},
                        {"role": "user", "content": f"我的命盘：\n{chart_json}\n\n今天的日期：{context['日期']}（{context['星期']}）\n农历：{context['农历']}\n流日干支：{context['干支']}\n{city_ctx}\n请基于我的命盘分析今天的运势。"},
                    ],
                    temperature=0.7,
                    max_tokens=800,
                    timeout=15,
                )
                reading = resp.choices[0].message.content or ""
                in_tok = resp.usage.prompt_tokens if resp.usage else 0
                out_tok = resp.usage.completion_tokens if resp.usage else 0
                cost = max(1, (in_tok + out_tok) // 1000)
                log_usage(key, "daily", cost, in_tok, out_tok)
                deduct_balance(key, cost)
            except Exception as e:
                reading = f"[AI 暂时不可用: {str(e)}]"
                log_usage(key, "daily", 1)
                deduct_balance(key, 1)
        else:
            reading = "AI 未配置，请设置 DEEPSEEK_API_KEY"
            log_usage(key, "daily", 1)
            deduct_balance(key, 1)

        return DailyResponse(success=True, data={
            "context": context,
            "reading": reading,
        })

    except Exception as e:
        return DailyResponse(success=False, error=str(e))

# ─── 当前大限分析 ────────────────────────────────────────────

class DaXianRequest(BaseModel):
    year: int = Field(..., ge=1900, le=2100)
    month: int = Field(..., ge=1, le=12)
    day: int = Field(..., ge=1, le=31)
    hour: float = Field(..., ge=0, le=23)
    gender: str = Field(..., pattern="^(male|female)$")
    style: str = Field("modern", pattern="^(modern|classical|poetic)$")
    city: str = Field("", max_length=100, description="所在城市")
    language: str = Field("zh-Hant", pattern="^(zh-Hant|zh-Hans|en)$", description="输出语言")

class DaXianResponse(BaseModel):
    success: bool
    data: Optional[dict] = None
    error: Optional[str] = None

# 星曜吉凶分类
JI_STARS = {'紫微','天府','天相','天梁','太阳','太阴','天同','武曲','左辅','右弼','文昌','文曲','天魁','天钺','禄存'}
SHA_STARS = {'七杀','破军','擎羊','陀罗'}

@app.post("/v1/daxian", response_model=DaXianResponse)
def daxian_analysis(req: DaXianRequest, key: str = Depends(get_api_key)):
    """当前十年大限详细分析"""


# ─── 大限分析（续） ────────────────────────────────────────────
    try:
        today = date.today()
        chart = run_engine(req.year, req.month, req.day, req.hour, req.gender)
        if not chart.get("success"):
            return DaXianResponse(success=False, error="排盘失败")
        
        current_age = today.year - req.year
        if today.month < req.month or (today.month == req.month and today.day < req.day):
            current_age -= 1
        
        current_daxian = None
        for dx in chart.get("大限", []):
            ages = dx["年龄"].replace("岁","").split("~")
            start = int(ages[0]); end = int(ages[1])
            if start <= current_age <= end:
                dx["起始年龄"] = start; dx["当前年龄"] = current_age
                current_daxian = dx; break
        
        if not current_daxian:
            return DaXianResponse(success=False, error="无法确定当前大限")
        
        palace_name = current_daxian["大限"]
        palace = chart.get("命盘", {}).get(palace_name, {})
        main_stars = palace.get("主星", []); minor_stars = palace.get("辅星", [])
        hua = palace.get("四化", [])
        
        ji_list = [s for s in main_stars + minor_stars if s in JI_STARS] + [h for h in hua if h in ('化禄','化权','化科')]
        sha_list = [s for s in main_stars + minor_stars if s in SHA_STARS] + [h for h in hua if h == '化忌']
        zhong_list = [s for s in main_stars + minor_stars if s not in JI_STARS and s not in SHA_STARS]
        
        DI_ZHI_LIST = ['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥']
        daxian_detail = {
            "当前年龄": current_age, "当前大限": palace_name,
            "大限年龄范围": current_daxian["年龄"],
            "宫位地支": DI_ZHI_LIST[palace.get("地支", 0)],
            "主星": main_stars, "辅星": minor_stars, "四化": hua,
            "吉星": ji_list, "煞星": sha_list, "中性星": zhong_list,
            "吉凶评价": "大吉" if len(ji_list) >= 2 and len(sha_list) == 0 else \
                       "吉" if len(ji_list) > len(sha_list) else \
                       "平" if len(ji_list) == len(sha_list) else \
                       "凶" if len(sha_list) > len(ji_list) else "平"
        }
        
        reading = ""
        if client:
            try:
prompt = load_daily_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
                cj = jmod.dumps(chart_data, ensure_ascii=False, indent=2)
                resp = client.chat.completions.create(
                    model="deepseek-chat",
                    messages=[
                        {"role": "system", "content": prompt},
                        {"role": "user", "content": f"我的命盘和当前所处大限：\n{cj}\n\n请详细分析我当前十年大限的格局，包括主星辅星吉凶星的相互作用，以及这十年的人生建议。{city_ctx}"}
                    ],
                    temperature=0.7, max_tokens=800, timeout=15,
                )
                reading = resp.choices[0].message.content or ""
                in_tok = resp.usage.prompt_tokens if resp.usage else 0
                out_tok = resp.usage.completion_tokens if resp.usage else 0
                cost = max(1, (in_tok + out_tok) // 1000)
                log_usage(key, "daxian", cost, in_tok, out_tok)
                deduct_balance(key, cost)
            except:
                reading = "[AI暂时不可用: ...]"
                log_usage(key, "daxian", 1)
                deduct_balance(key, 1)
        else:
            log_usage(key, "daxian", 1)
            deduct_balance(key, 1)
        
        return DaXianResponse(success=True, data={"daxian": daxian_detail, "reading": reading})
    except Exception as e:
        return DaXianResponse(success=False, error=str(e))

