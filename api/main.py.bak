_DAXIAN_FREE_LIMIT: set = set()
DI_ZHI_LIST = ['子','丑','寅','卯','巳','午','未','申','酉','戌','亥']

@app.post("/v1/daxian-free")
def daxian_free(req: DaXianRequest, request: Request):
    ip = request.client.host if request.client else "unknown"
    if ip in _DAXIAN_FREE_LIMIT:
        return {"success": True, "data": {"daxian": None, "reading": '<div style="text-align:center;padding:10px 0"><div style="font-size:32px;margin-bottom:8px">⏳</div><div style="color:#e0c8ff;font-size:16px;font-weight:600;margin-bottom:6px">免费大限分析已使用</div><div style="color:#6a5a8a;font-size:13px;margin-bottom:14px">解锁无限次大限详解</div><a href="/shop.html" target="_blank" style="display:inline-block;padding:10px 24px;background:linear-gradient(135deg,#7b68ee,#5a4acd);color:#fff;border-radius:10px;text-decoration:none;font-size:14px;font-weight:600;letter-spacing:1px">🛒 购买Key解锁</a></div>', "free_used": True}}
    try:
        today = date.today()
        chart = run_engine(req.year, req.month, req.day, req.hour, req.gender)
        if not chart.get("success"):
            return {"success": False, "error": "排盘失败"}
        current_age = today.year - req.year
        if today.month < req.month or (today.month == req.month and today.day < req.day):
            current_age -= 1
        current_daxian = None
        for dx in chart.get("大限", []):
            ages = dx["年龄"].replace("岁","").split("~")
            if int(ages[0]) <= current_age <= int(ages[1]):
                dx["当前年龄"] = current_age; current_daxian = dx; break
        if not current_daxian:
            return {"success": False, "error": "无法确定当前大限"}
        pn = current_daxian["大限"]; p = chart.get("命盘",{}).get(pn,{})
        j = [s for s in p.get("主星",[])+p.get("辅星",[]) if s in JI_STARS]+[h for h in p.get("四化",[]) if h in ('化禄','化权','化科')]
        sh = [s for s in p.get("主星",[])+p.get("辅星",[]) if s in SHA_STARS]+[h for h in p.get("四化",[]) if h=='化忌']
        z = [s for s in p.get("主星",[])+p.get("辅星",[]) if s not in JI_STARS and s not in SHA_STARS]
        dd = {"当前年龄":current_age,"当前大限":pn,"大限年龄范围":current_daxian["年龄"],
              "宫位地支":DI_ZHI_LIST[p.get("地支",0)],"主星":p.get("主星",[]),
              "辅星":p.get("辅星",[]),"四化":p.get("四化",[]),"吉星":j,"煞星":sh,
              "中性星":z,"吉凶评价":"大吉"if len(j)>=2 and len(sh)==0 else "吉"if len(j)>len(sh) else "平"if len(j)==len(sh) else "凶"}
        reading = ""
        if client:
prompt = load_daily_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
                    {"role":"system","content":prompt},
                    {"role":"user","content":f"我的命盘大限信息：\n{cj}{city_ctx}\n\n请给出前200字精华预览。"}
                ],temperature=0.7,max_tokens=400,timeout=15)
                full = resp.choices[0].message.content or ""
                reading = full[:200]+("..." if len(full)>200 else "")+'<div style="margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,200,80,.15);text-align:center"><div style="font-size:12px;color:#8a7a5a;margin-bottom:10px">🔒 免费预览（200字）· 仅限1次</div><a href="/shop.html" target="_blank" style="display:inline-block;padding:10px 24px;background:linear-gradient(135deg,#7b68ee,#5a4acd);color:#fff;border-radius:10px;text-decoration:none;font-size:14px;font-weight:600;letter-spacing:1px">🛒 购买Key解锁完整大限解读</a></div>'
            except: reading = "AI解读暂时不可用"
        _DAXIAN_FREE_LIMIT.add(ip)
        return {"success":True,"data":{"daxian":dd,"reading":reading,"free_used":False}}
    except Exception as e:
        return {"success":False,"error":str(e)}

# ─── 大限Prompt ──────────────────────────────────────────────
def load_daxian_prompt(style: str, language: str = "zh-Hant") -> str:
    """大限分析提示词（支持zh-Hant/zh-Hans/en）"""
    lang_zh = "zh-Hant" if language == "zh-Hant" else "zh-Hans"
    
    if language == "en":
        prompts = {
            "modern": """You are a Zi Wei Dou Shu consultant analyzing the user's current decade period (大限) in a professional yet warm tone.

Analysis framework:
1. **Decade Palace** — Which palace governs this decade, and what life domain it represents
2. **Main Star Influence** — How the palace's main star shapes this decade
3. **Assistant Stars** — Auspicious/inauspicious star energy amplification
4. **Four Transformations** — How Hua Lu / Hua Quan / Hua Ke / Hua Ji play out in this decade
5. **Life Advice** — Specific guidance for career, wealth, relationships and health

Note: Be human, specific. End with "This is for entertainment and reference only." """,
            "classical": """You are a classical Zi Wei Dou Shu master analyzing the decade period in semi-classical English.
1. On the palace and star combinations 2. On the Four Transformations' auspiciousness 3. On how to navigate
End with "This is for entertainment and reference only." """,
            "poetic": """You are a healing astrologer interpreting the decade period through poetic language.
3-5 sentences per paragraph, beautiful language, focusing on life stage guidance.
Deliver warm, uplifting energy. End with "This is for entertainment and reference only." """
        }
    else:
        prompts = {
            "modern": f"""你是一个精通紫微斗数的命理咨询师，以专业但温和的语气为用户分析当前的十年大运。

分析框架：
1. **大限宫位解读** — 当前大限落在什么宫位，该宫位是用户这十年的人生主战场
2. **主星特质** — 该宫主星在这十年中如何发挥影响力
3. **辅星加成** — 吉辅/煞辅的能量叠加效果
4. **四化引动** — 化禄/化权/化科/化忌在本大限中的作用
5. **人生建议** — 针对当前大限的具体建议（事业/财运/感情/健康）

注意：说人话，分析具体。请使用{lang_zh}回答。注明"仅供娱乐参考"。""",
            "classical": f"""你是传统紫微斗数命师，以半文言分析十年大限。
1. 论大限宫垣星曜之组合 2. 断四化引动之吉凶 3. 给出趋吉避凶之建议
请使用{lang_zh}回答。结尾注明"仅供娱乐参考"。""",
            "poetic": f"""你是治愈系命理师，以诗意温暖的语言解读十年大限。
每段3-5句，语言优美，侧重人生阶段建议。传递温暖正向力量。
请使用{lang_zh}回答。结尾注明"仅供娱乐参考"。"""
        }
    return prompts.get(style, prompts["modern"])

# ─── 免费每日运势 ──────────────────────────────────────────────
_DAILY_FREE_LIMIT: dict = {}

@app.post("/v1/daily-free")
def daily_free(req: DailyRequest, request: Request):
    ip = request.client.host if request.client else "unknown"
    today_str = date.today().isoformat()
    key = f"{ip}:{today_str}"
    if key in _DAILY_FREE_LIMIT:
        return {"success": True, "data": {"free_used": True, "context": {}, "reading": '<div style="text-align:center;padding:10px 0"><div style="font-size:32px;margin-bottom:8px">🌅</div><div style="color:#e0c8ff;font-size:16px;font-weight:600;margin-bottom:6px">今日免费运势已使用</div><div style="color:#6a5a8a;font-size:13px;margin-bottom:14px">解锁无限次每日运势</div><a href="/shop.html" target="_blank" style="display:inline-block;padding:10px 24px;background:linear-gradient(135deg,#2a8a5a,#1a6a40);color:#fff;border-radius:10px;text-decoration:none;font-size:14px;font-weight:600;letter-spacing:1px">🛒 购买Key解锁</a></div>'}}
    _DAILY_FREE_LIMIT[key] = True
    try:
        today = date.today()
        chart = run_engine(req.year, req.month, req.day, req.hour, req.gender)
        today_chart = {}
        if chart.get("success"):
            lr = jmod.dumps({"year":today.year,"month":today.month,"day":today.day,"hour":12,"gender":"male"})
            proc = subprocess.run([_NODE,str(ENGINE_PATH)],input=lr,capture_output=True,text=True,timeout=10,cwd=str(BASE_DIR))
            if proc.returncode==0: today_chart=jmod.loads(proc.stdout)
        ti = today_chart.get("基本信息",{})
        ctx = {"日期":f"{today.year}年{today.month}月{today.day}日","农历":ti.get("农历",""),"干支":ti.get("八字","").split(" ")[0] if ti.get("八字") else "","星期":"日一二三四五六"[today.weekday()]}
        reading = ""
        if client:
prompt = load_daily_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
prompt = load_daily_prompt(req.style, req.language)
                city_ctx = get_city_context(req.city, req.language)
                prompt = load_daxian_prompt(req.style, req.language)
                    {"role":"user","content":f"我的命盘：\n{cj}\n\n今天的日期：{ctx['日期']}（{ctx['星期']}）\n农历：{ctx['农历']}\n流日干支：{ctx['干支']}\n{city_ctx}\n请给出今日运势分析（前200字精华预览）。"}
                ],temperature=0.7,max_tokens=400,timeout=15)
                full=resp.choices[0].message.content or ""
                reading=full[:200]+("..." if len(full)>200 else "")+'<div style="margin-top:16px;padding-top:14px;border-top:1px solid rgba(100,255,180,.15);text-align:center"><div style="font-size:12px;color:#5a9a7a;margin-bottom:10px">🔒 免费预览（200字）· 每日仅限1次</div><a href="/shop.html" target="_blank" style="display:inline-block;padding:10px 24px;background:linear-gradient(135deg,#2a8a5a,#1a6a40);color:#fff;border-radius:10px;text-decoration:none;font-size:14px;font-weight:600;letter-spacing:1px">🛒 购买Key解锁完整运势</a></div>'
            except: reading="AI解读暂时不可用"
        return {"success":True,"data":{"context":ctx,"reading":reading,"free_used":False}}
    except Exception as e:
        return {"success":False,"error":str(e)}

# ─── 商店接口 ────────────────────────────────────────────────
PACKAGES = {
    "trial":{"name":"体验包","price":9.9,"quota":3,"color":"#88bbff"},
    "starter":{"name":"入门包","price":49,"quota":10,"color":"#88dd88"},
    "pro":{"name":"进阶包","price":199,"quota":100,"color":"#ffcc44"},
    "enterprise":{"name":"专业包","price":499,"quota":500,"color":"#ff6688"},
}
OVERSEAS_PACKAGES = {
    "starter":{"name":"Starter","price":9.9,"quota":10,"currency":"USD"},
    "standard":{"name":"Standard","price":29.9,"quota":50,"currency":"USD"},
    "annual":{"name":"Annual","price":99,"quota":500,"currency":"USD"},
    "business":{"name":"Business","price":49,"quota":2000,"currency":"USD","monthly":True},
    "whitelabel":{"name":"WhiteLabel","price":999,"quota":99999,"currency":"USD","monthly":True},
}

@app.get("/v1/packages")
def get_packages():
    return {"success":True,"data":{"cn":PACKAGES,"overseas":OVERSEAS_PACKAGES}}

@app.post("/v1/key/create")
def create_key(req: KeyCreateRequest):
    key = "zw_" + secrets.token_hex(16)
    db_conn.execute("INSERT INTO api_keys (key, name, balance) VALUES (?, ?, ?)",(key,req.name,req.quota))
    db_conn.commit()
    return {"success":True,"data":{"key":key,"balance":req.quota}}

@app.post("/v1/order/create")
def create_order(package: str, pay_method: str = "alipay"):
    if package not in PACKAGES: raise HTTPException(400,"Invalid package")
    pkg = PACKAGES[package]
    order_id = f"ORD{datetime.now().strftime('%Y%m%d%H%M%S')}{secrets.token_hex(4)}"
    db_conn.execute("INSERT INTO orders (id, package, amount, pay_method) VALUES (?,?,?,?)",(order_id,package,pkg["price"],pay_method))
    db_conn.commit()
    return {"success":True,"data":{"order_id":order_id,"amount":pkg["price"],"package":package,"package_name":pkg["name"]}}

@app.post("/v1/order/pay")
def pay_order(order_id: str):
    order = db_conn.execute("SELECT * FROM orders WHERE id=?",(order_id,)).fetchone()
    if not order: raise HTTPException(404,"Order not found")
    if order[5] != "pending": raise HTTPException(400,"Order already paid/cancelled")
    package = order[2]; pkg = PACKAGES.get(package)
    if not pkg: raise HTTPException(400,"Invalid package")
    key = "zw_" + secrets.token_hex(16)
    db_conn.execute("INSERT INTO api_keys (key, name, balance) VALUES (?,?,?)",(key,f"自动创建-{pkg['name']}",pkg["quota"]))
    db_conn.execute("UPDATE orders SET status='paid', api_key=?, paid_at=datetime('now') WHERE id=?",(key,order_id))
    db_conn.commit()
    return {"success":True,"data":{"key":key,"quota":pkg["quota"],"package":pkg["name"]}}

@app.get("/v1/key/balance")
def check_balance(key: str = Depends(get_api_key)):
    row = db_conn.execute("SELECT balance FROM api_keys WHERE key=?",(key,)).fetchone()
    return {"success":True,"balance":row[0] if row else 0}

@app.get("/v1/usage")
def check_usage(key: str = Depends(get_api_key), limit: int = 20):
    rows = db_conn.execute("SELECT endpoint, cost, created_at FROM usage_log WHERE api_key=? ORDER BY created_at DESC LIMIT ?",(key,limit)).fetchall()
    return {"success":True,"data":[{"endpoint":r[0],"cost":r[1],"time":r[2]} for r in rows]}

@app.get("/v1/redeem")
def redeem(code: str):
    REDEEM_CODES = {"TEST10":10,"VIP50":50}
    quota = REDEEM_CODES.get(code)
    if not quota: raise HTTPException(400,"Invalid code")
    return {"success":True,"data":{"code":code,"quota":quota}}

