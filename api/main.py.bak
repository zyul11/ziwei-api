"""
紫微斗数 API — 排盘 + AI 解读 + API Key 计费
"""
import json
import sqlite3
import subprocess
import secrets
import os
import json as jmod
from datetime import datetime, timedelta, date
from pathlib import Path
from contextlib import asynccontextmanager
from fastapi.staticfiles import StaticFiles

# Load .env for local dev
env_path = Path(__file__).parent.parent / ".env"
if env_path.exists():
    for line in env_path.read_text().strip().splitlines():
        if "=" in line and not line.startswith("#"):
            k, v = line.split("=", 1)
            os.environ.setdefault(k.strip(), v.strip())

from fastapi import FastAPI, HTTPException, Header, Depends, Request
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import FileResponse
from pydantic import BaseModel, Field
from openai import OpenAI
from typing import Optional

# ─── config ────────────────────────────────────────────────
BASE_DIR = Path(__file__).parent.parent
ENGINE_PATH = BASE_DIR / "api" / "ziwei-engine.js"
DATABASE_PATH = Path("/data/ziwei.db") if Path("/data").exists() else BASE_DIR / "data" / "ziwei.db"
DEEPSEEK_API_KEY = ""

# PayJS 支付配置（从 .env 读取）
PAYJS_MCHID = os.getenv("PAYJS_MCHID", "your_mchid_here")
PAYJS_KEY = os.getenv("PAYJS_KEY", "your_key_here")
PAYJS_NOTIFY_URL = os.getenv("PAYJS_NOTIFY_URL", "")

# will be set during startup
client: Optional[OpenAI] = None
db_conn: Optional[sqlite3.Connection] = None

# ─── lifespan ───────────────────────────────────────────────
@asynccontextmanager
async def lifespan(app: FastAPI):
    global client, db_conn
    
    import os
    api_key = os.getenv("DEEPSEEK_API_KEY", "")
    if api_key and api_key != "sk-your-key-here":
        client = OpenAI(api_key=api_key, base_url="https://api.deepseek.com")
    
    # init DB
    DATABASE_PATH.parent.mkdir(parents=True, exist_ok=True)
    db_conn = sqlite3.connect(str(DATABASE_PATH), check_same_thread=False)
    db_conn.execute("""
        CREATE TABLE IF NOT EXISTS api_keys (
            key TEXT PRIMARY KEY,
            name TEXT,
            balance INTEGER DEFAULT 0,
            created_at TEXT DEFAULT (datetime('now')),
            expires_at TEXT,
            active INTEGER DEFAULT 1
        )
    """)
    db_conn.execute("""
        CREATE TABLE IF NOT EXISTS usage_log (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            api_key TEXT,
            endpoint TEXT,
            input_tokens INTEGER DEFAULT 0,
            output_tokens INTEGER DEFAULT 0,
            cost INTEGER DEFAULT 1,
            created_at TEXT DEFAULT (datetime('now'))
        )
    """)
    db_conn.execute("""
        CREATE TABLE IF NOT EXISTS orders (
            id TEXT PRIMARY KEY,
            package TEXT NOT NULL,
            amount REAL NOT NULL,
            pay_method TEXT DEFAULT 'alipay',
            status TEXT DEFAULT 'pending',
            api_key TEXT,
            payjs_order_id TEXT,
            created_at TEXT DEFAULT (datetime('now')),
            paid_at TEXT
        )
    """)
    db_conn.commit()
    
    yield
    
    if db_conn:
        db_conn.close()

app = FastAPI(title="紫微斗数 API", version="1.0.0", lifespan=lifespan)

# CORS — 允许本地网页测试
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# 静态文件 — index.html shop.html 等通过 API 服务器统一提供
static_dir = Path(__file__).parent.parent
if static_dir.exists():
    app.mount("/static", StaticFiles(directory=str(static_dir)), name="static")
    from fastapi.responses import RedirectResponse, HTMLResponse
    @app.get("/app/{page}")
    def serve_page(page: str):
        file_path = static_dir / page
        if file_path.exists():
            return HTMLResponse(file_path.read_text(encoding="utf-8"))
        return HTMLResponse("Page not found", status_code=404)
    @app.get("/")
    async def serve_root():
        return FileResponse(static_dir / "index.html")

# ─── models ─────────────────────────────────────────────────
class PaiPanRequest(BaseModel):
    year: int = Field(..., ge=1900, le=2100, description="公历年")
    month: int = Field(..., ge=1, le=12, description="公历月")
    day: int = Field(..., ge=1, le=31, description="公历日")
    hour: float = Field(..., ge=0, le=23, description="小时(0~23)")
    gender: str = Field(..., pattern="^(male|female)$", description="性别")
    style: str = Field("modern", pattern="^(modern|classical|poetic)$", description="解读风格")
    city: str = Field("", max_length=100, description="所在城市，如新加坡/台北/香港/吉隆坡")
    language: str = Field("zh-Hant", pattern="^(zh-Hant|zh-Hans|en)$", description="输出语言")

class PaiPanResponse(BaseModel):
    success: bool
    data: Optional[dict] = None
    error: Optional[str] = None

class KeyCreateRequest(BaseModel):
    name: str = "default"
    quota: int = 500

class KeyCreateResponse(BaseModel):
    key: str
    balance: int

# ─── middleware ─────────────────────────────────────────────
def get_api_key(authorization: str = Header(None)):
    if not authorization:
        raise HTTPException(401, "Missing Authorization header")
    key = authorization.replace("Bearer ", "").strip()
    
    cur = db_conn.execute("SELECT balance, active, expires_at FROM api_keys WHERE key=?", (key,))
    row = cur.fetchone()
    if not row:
        raise HTTPException(403, "Invalid API key")
    if not row[1]:
        raise HTTPException(403, "API key is disabled")
    if row[2] and datetime.fromisoformat(row[2]) < datetime.now():
        raise HTTPException(403, "API key expired")
    if row[0] <= 0:
        raise HTTPException(402, "Insufficient balance")
    return key

def deduct_balance(key: str, cost: int = 1):
    db_conn.execute("UPDATE api_keys SET balance = balance - ? WHERE key = ?", (cost, key))
    db_conn.commit()

def log_usage(key: str, endpoint: str, cost: int = 1, in_tokens: int = 0, out_tokens: int = 0):
    db_conn.execute(
        "INSERT INTO usage_log (api_key, endpoint, input_tokens, output_tokens, cost) VALUES (?, ?, ?, ?, ?)",
        (key, endpoint, in_tokens, out_tokens, cost)
    )
    db_conn.commit()

# ─── engine call ────────────────────────────────────────────
import shutil
_NODE = shutil.which("node") or "/Users/air/.local/bin/node"

def run_engine(year: int, month: int, day: int, hour: float, gender: str) -> dict:
    input_data = json.dumps({"year": year, "month": month, "day": day, "hour": hour, "gender": gender})
    result = subprocess.run(
        [_NODE, str(ENGINE_PATH)],
        input=input_data,
        capture_output=True,
        text=True,
        timeout=10,
        cwd=str(BASE_DIR),
    )
    if result.returncode != 0:
        raise RuntimeError(f"Engine error: {result.stderr}")
    return json.loads(result.stdout)

# ─── AI prompts ─────────────────────────────────────────────
def load_style_prompt(style: str, language: str = "zh-Hant") -> str:
    """加载对应风格的提示词（支持zh-Hant/zh-Hans/en）"""
    lang_zh = "zh-Hant" if language == "zh-Hant" else "zh-Hans"
    
    if language == "en":
        prompts = {
            "modern": """You are a Zi Wei Dou Shu expert, interpreting a birth chart in a friendly, approachable tone.

Guidelines:
- Use casual, conversational English, add emojis occasionally
- ONLY use data actually present in the chart — never fabricate information
- Focus on: Palace of Life (命宫) main star traits, Wealth Palace (财帛宫), Career Palace (官禄宫), Spouse Palace (夫妻宫)
- If the user provided a city, incorporate the city's industries, local culture and geography into your reading
- Give practical, actionable advice — not generic platitudes
- End with: "This is for entertainment and reference only."
""",
            "classical": """You are a classical Zi Wei Dou Shu master, interpreting the chart in a semi-classical English style.

Guidelines:
- Reference traditional judgment sayings
- Emphasize the Five Elements (五行) cycle and Four Transformations (四化)
- Analyze auspicious and inauspicious star combinations in each palace
- End with: "This is for entertainment and reference only."
""",
            "poetic": """You are a healing astrology guide, interpreting the chart through poetic, warm language.

Guidelines:
- Each paragraph 3-5 lines, lyrical and rhythmic
- Focus on personality portrait and life stage advice
- Deliver warm, uplifting energy
- End with: "This is for entertainment and reference only."
""",
        }
    else:
        prompts = {
            "modern": f"""你是一个精通紫微斗数的命理师，请以年轻、亲切的语气为用户解读命盘。

注意事项：
- 使用口语化表达，适当加入emoji
- 只使用命盘已有数据，不编造不存在的信息
- 分析重点：命宫主星特性、财帛宫、官禄宫、夫妻宫
- 如果用户提供了所在城市，结合该城市的地理方位、当地行业特点、当地文化习俗给出针对性解读
- 给出实用建议而非通用鸡汤
- 请使用{lang_zh}回答
- 结尾注明"仅供娱乐参考，内容不构成专业建议"
""",
            "classical": f"""你是精通紫微斗数的传统命理师，以半文言风格为用户解读命盘。
注意事项：
- 适当引用传统断语
- 强调五行生克、四化流转
- 分析各宫星曜组合的吉凶
- 请使用{lang_zh}回答
- 结尾注明"仅供娱乐参考"
""",
            "poetic": f"""你是治愈系紫微占星师，以诗意短句为用户解读命盘。
注意事项：
- 每段3-5句，语言优美有韵律
- 侧重性格画像和人生阶段建议
- 传递温暖正向的力量
- 请使用{lang_zh}回答
- 结尾注明"仅供娱乐参考"
""",
        }
    return prompts.get(style, prompts["modern"])

