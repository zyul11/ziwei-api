  </div>
  <div style="text-align:center;padding:8px 0 24px;font-size:10px;color:#4a3018;line-height:1.6;letter-spacing:.5px">
    ⚠️ 内容仅供娱乐参考，不构成专业建议
  </div>

</div><!-- /container -->

<!-- Key Modal -->
<div class="key-modal-overlay" id="keyModal">
  <div class="key-modal">
    <div class="modal-icon">🔑</div>
    <h2 style="margin-bottom:6px">需要 API Key</h2>
    <p style="color:#9a7850;font-size:13px;margin-bottom:16px">输入已购买的 API Key 即可使用</p>
    <div style="background:#1e1612;border:1px solid #3a2a1e;border-radius:10px;padding:14px;margin-bottom:16px">
      <div style="font-size:11px;color:#8a7050;margin-bottom:4px;letter-spacing:1px;text-align:center">💳 在线支付自动获取 Key</div>
      <div style="font-size:10px;color:#9a7850;text-align:center">前往 <a href="/shop.html" style="color:#e8a040;text-decoration:none">购买页面</a> 选择套餐，支付后即时开通</div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-secondary" onclick="document.getElementById('keyModal').classList.remove('show')" style="flex:1">我知道了</button>
      <button class="btn btn-primary" onclick="location.href='shop.html'" style="flex:1">去购买 Key</button>
    </div>
  </div>
</div>

